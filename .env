# ╔════════════════════════════════════════════════════════════╗
# ║  Docker 環境設定 - 區分容器內部(INTERNAL)和外部(EXTERNAL)    ║
# ║  三人協作設定 (前端 + 後端 + AI後端)                        ║
# ╚════════════════════════════════════════════════════════════╝

# ═════════════════════════════════════════════════════════════
# 【1】Django 應用設定
# ═════════════════════════════════════════════════════════════
DEBUG=False
DJANGO_SECRET_KEY=change-this-secret-key-in-production-please-use-random-string
DJANGO_DEV_MODE=false

# 允許的主機列表（用於域名驗證）
# 多個主機用逗號分隔
# 包含：伺務名(docker-compose)、localhost、IP 地址
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend,django-backend,35.201.135.229

# ═════════════════════════════════════════════════════════════
# 【2】PostgreSQL 資料庫設定
# ═════════════════════════════════════════════════════════════
# 資料庫連接地址和端口（統一使用 9090）
DB_HOST=postgres
DB_PORT=9090

# 資料庫名、用戶、密碼（两個環境相同）
DB_NAME=auth_db
DB_USER=auth_user
DB_PASSWORD=auth_password_123

# ═════════════════════════════════════════════════════════════
# 【3】MinIO 對象存储設定
# ═════════════════════════════════════════════════════════════
# 【容器外部】宿主機瀏覽器/外部訪問
MINIO_EXTERNAL_URL=http://localhost:9000

# 【容器內部通信】Backend 連接 MinIO 時使用的地址
# Docker 容器內通過伺務名訪問
MINIO_ENDPOINT=minio:9000

# MinIO 認證信息
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=processed-images
MINIO_SECURE=False

# ═════════════════════════════════════════════════════════════
# 【4】前端設定（CORS）
# ═════════════════════════════════════════════════════════════
# 【容器外部】宿主機瀏覽器訪問
FRONTEND_EXTERNAL_URL=http://localhost:5173

# 【容器內部】Docker 容器網絡內訪問
FRONTEND_INTERNAL_URL=http://frontend:5173

# CORS 白名单 - 包括所有可能的前端和伺務地址
# 包括：
#   - localhost:5173 (宿主機開發)
#   - localhost:8080 (宿主機生產)
#   - localhost:8002 (本地 Try_On)
#   - frontend:5173 (Docker 容器內前端)
#   - try_on:8002 (Docker 容器內 Try_On)
#   - 0.0.0.0:5173 (任意網卡)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:8002,http://127.0.0.1:5173,http://frontend:5173,http://try_on:8002,http://0.0.0.0:5173

# 是否允許所有来源（開發 false，生產 false）
CORS_ALLOW_ALL_ORIGINS=False

# ═════════════════════════════════════════════════════════════
# 【5】AI 後端設定（Try_On 伺務）
# ═════════════════════════════════════════════════════════════
# 【容器外部】宿主機/前端瀏覽器訪問
AI_BACKEND_EXTERNAL_URL=http://localhost:8002

# 【容器內部通信】Backend 調用 Try_On 伺務時使用的地址
# Docker 容器內通過伺務名訪問
AI_BACKEND_URL=http://ai-container:8002

# ═════════════════════════════════════════════════════════════
# 【5.1】AI 後端具體端点路由
# ═════════════════════════════════════════════════════════════
# 衣伺去背處理端点
AI_CLOTHES_REMOVE_BG_ENDPOINT=/virtual_try_on/clothes/remove_bg

# 人物去背處理端点
AI_USER_FITTING_MODULES_ENDPOINT=/virtual_try_on/fitting/modules

# 虛拟試穿合成端点
AI_VIRTUAL_TRY_ON_FITTING_ENDPOINT=/virtual_try_on/fitting/generate

# ═════════════════════════════════════════════════════════════
# 【6】檔案上傳設定
# ═════════════════════════════════════════════════════════════
# 最大上傳檔案大小（字節）
# 預設：10 MB (10485760 bytes)
MAX_UPLOAD_SIZE=10485760

# ═════════════════════════════════════════════════════════════
# 【說明】環境變量使用指南
# ═════════════════════════════════════════════════════════════
# 開發環境設置：
#   1. 前端：npm run dev (localhost:5173)
#   2. 後端：python manage.py runserver 0.0.0.0:30000
#   3. AI (本地)：python test_file/mock_ai_backend.py --port 8002
#   4. 數據庫：已在 Docker 中運行 (postgres:9090)
#   5. MinIO：已在 Docker 中運行 (minio:9000)
#
# Docker 容器環境：
#   • 容器內必須使用 minio:9000 而非 localhost:9000
#   • 使用 172.17.0.1 訪問主機上的伺務
#   • MINIO_CONTAINER_ENDPOINT 會在需要時自動使用
#
# 生產環境設置：
#   1. 更新 DJANGO_ALLOWED_HOSTS 為實際域名
#   2. 更新 FRONTEND_URL 為前端實際地址
#   3. 更新 CORS_ALLOWED_ORIGINS
#   4. 更新 AI_BACKEND_URL 為生產 AI 伺務器
#   5. 修改 DEBUG=False
#   6. 設置強安全的 DJANGO_SECRET_KEY