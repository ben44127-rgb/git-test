# ╔═════════════════════════════════════════════════════════════╗
# ║         Angular Clothing App - 環境配置 (ENV)               ║
# ║  三人協作配置 (前端 + 後端 + AI後端)                        ║
# ╚═════════════════════════════════════════════════════════════╝

# ═════════════════════════════════════════════════════════════
# 【1】Django 應用配置
# ═════════════════════════════════════════════════════════════
DEBUG=False
DJANGO_SECRET_KEY=change-this-secret-key-in-production-please-use-random-string
DJANGO_DEV_MODE=false

# 允許的主機列表（用於域名驗證）
# 開發環境：允許 localhost 和 127.0.0.1
# 生產環境：添加實際的域名
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,django-backend

# ═════════════════════════════════════════════════════════════
# 【2】PostgreSQL 數據庫配置 (用户认证)
# ═════════════════════════════════════════════════════════════
DB_HOST=localhost
DB_PORT=9090
DB_NAME=auth_db
DB_USER=auth_user
DB_PASSWORD=auth_password_123

# ═════════════════════════════════════════════════════════════
# 【3】MinIO 物件儲存配置
# ═════════════════════════════════════════════════════════════
# 外部訪問地址（從容器外部/前端訪問）
MINIO_ENDPOINT=localhost:9000

# 容器內部訪問地址（当在Docker中运行时）
# 注意：容器內只能通過 minio:9000 訪問，不是 localhost:9000
MINIO_CONTAINER_ENDPOINT=minio:9000

# MinIO 認證信息
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=processed-images
MINIO_SECURE=False

# MinIO 返回給前端的 URL（用於圖片預覽）
MINIO_EXTERNAL_URL=http://localhost:9000

# ═════════════════════════════════════════════════════════════
# 【4】前端配置（CORS 和 重定向）
# ═════════════════════════════════════════════════════════════
# 前端應用地址（用於 CORS 白名單）
FRONTEND_URL=http://localhost:5173

# CORS 允許的來源（逗號分隔）
# 開發環境：localhost:5173
# 生產環境：add your frontend domain
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 是否允許所有來源（開發環境為 true，生產環境為 false）
CORS_ALLOW_ALL_ORIGINS=False

# ═════════════════════════════════════════════════════════════
# 【5】AI 後端配置（與其他組員協作）
# ═════════════════════════════════════════════════════════════
# ⚠️  【關鍵】單一 AI 後端 URL - 用戶手動切換
# ───────────────────────────────────────────────────────────
# 本地開發（模擬 AI）：
#   AI_BACKEND_URL=http://localhost:8002
#
# 連接真實 AI（與組員協作）：
#   AI_BACKEND_URL=http://[真實AI服務器IP]:8002/virtual_try_on/clothes/remove_bg
#
# Docker 容器環境（模擬 AI）：
#   AI_BACKEND_URL=http://172.17.0.1:8002
# ───────────────────────────────────────────────────────────
# 【重要】容器內無法訪問主機的 localhost，必須使用正確的網關地址:
# - Linux Docker: http://172.17.0.1:8002
# - Docker Desktop (Mac/Windows): http://host.docker.internal:8002
# 當前運行環境: Linux Docker - 使用 172.17.0.1
AI_BACKEND_URL=http://172.17.0.1:8002

# AI 虛擬試穿端點（相對於 AI_BACKEND_URL 的路徑）
AI_VIRTUAL_TRY_ON_ENDPOINT=/virtual_try_on/clothes/combine

# ═════════════════════════════════════════════════════════════
# 【6】檔案上傳配置
# ═════════════════════════════════════════════════════════════
# 最大上傳檔案大小（字節）
# 預設：10 MB (10485760 bytes)
MAX_UPLOAD_SIZE=10485760

# ═════════════════════════════════════════════════════════════
# 【說明】環境變量使用指南
# ═════════════════════════════════════════════════════════════
# 開發環境設置：
#   1. 前端：npm run dev (localhost:5173)
#   2. 後端：python manage.py runserver 0.0.0.0:30000
#   3. AI (本地)：python test_file/mock_ai_backend.py --port 8002
#   4. 數據庫：已在 Docker 中運行 (postgres:9090)
#   5. MinIO：已在 Docker 中運行 (minio:9000)
#
# Docker 容器環境：
#   • 容器內必須使用 minio:9000 而非 localhost:9000
#   • 使用 172.17.0.1 訪問主機上的服務
#   • MINIO_CONTAINER_ENDPOINT 會在需要時自動使用
#
# 生產環境設置：
#   1. 更新 DJANGO_ALLOWED_HOSTS 為實際域名
#   2. 更新 FRONTEND_URL 為前端實際地址
#   3. 更新 CORS_ALLOWED_ORIGINS
#   4. 更新 AI_BACKEND_URL 為生產 AI 服務器
#   5. 修改 DEBUG=False
#   6. 設置強安全的 DJANGO_SECRET_KEY
